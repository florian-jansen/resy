{
  "permission": {
    "bash": {
      "grep *": "allow",
      "head *": "allow",
      "cat *": "allow",
      "*": "allow",
      "sed *": "allow",
      "echo *": "allow",
      "python3 *": "allow",
      "cd *": "allow",
      "Rscript *": "allow",
      "\"##D|\"##Q *": "allow",
      "\"\\\\$\\\\$', txt[i])) {\n    txt[i] <- sub('\" *": "allow"
    },
    "edit": {
      "*.R": "allow",
      "*.Rmd": "allow",
      "*.md": "allow",
      "*.py": "allow",
      "*/NAMESPACE": "allow"
    },
    "executeCode": {
      "*": "allow"
    },
    "external_directory": {
      "/tmp/*": "allow"
    }
  }
}